  },
  "dependencies": {
    "hono": "4.12.12"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.12.2",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "jiti": "2.6.1",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1",
    "wrangler": "4.80.0"
  }
