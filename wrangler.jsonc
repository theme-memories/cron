{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "workers_dev": false,
  "preview_urls": false,
  "triggers": {
    "crons": ["*/10 * * * *"],
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true,
      "destinations": ["grafana-logs"],
    },
    "traces": {
      "enabled": true,
      "destinations": ["grafana-traces"],
    },
  },
  "placement": {
    "mode": "smart",
  },
  "compatibility_date": "2026-06-16",
  "compatibility_flags": ["nodejs_compat"],
  "name": "cron",
  "main": "src/index.ts",
  "secrets_store_secrets": [
    {
      "binding": "OPENWEATHERMAP_API_KEY",
      "store_id": "c5b03c1fc22547d0bb1ee70629d4b6dd",
      "secret_name": "OPENWEATHERMAP_API_KEY",
    },
  ],
  "r2_buckets": [
    {
      "binding": "R2_BUCKET",
      "bucket_name": "object",
    },
  ],
}
